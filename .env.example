# ================================================================================
# MY RETAIL - Environment Configuration
# ================================================================================
# สำเนาไฟล์นี้เป็น .env แล้วเติมค่าจริง
# NEVER commit ไฟล์ .env ขึ้น GitHub!
# ================================================================================

# Database Configuration (Neon.tech)
# ใช้ชื่อเดียวกับ Railway environment variables
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGDATABASE=your_database_name
PGUSER=your_username
PGPASSWORD=your_password

# Application Environment
APP_ENV=development
# APP_ENV=production (สำหรับ production)

# Debug Mode (true = แสดง error details, false = production mode)
DEBUG_MODE=true

# Timezone
TIMEZONE=Asia/Bangkok

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600